OUTLINE_IMAGE=ghcr.io/arturstm/outline-ru:latest

# Public domains. Point both DNS A records to the server.
OUTLINE_HOST=docs.example.com
DEX_HOST=auth.docs.example.com

URL=https://docs.example.com
PORT=3000
NODE_ENV=production

# Generate with:
# openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
UTILS_SECRET=change_me_generate_with_openssl_rand_hex_32

POSTGRES_DB=outline
POSTGRES_USER=outline
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgres://outline:change_me_postgres_password@postgres:5432/outline?sslmode=disable
PGSSLMODE=disable

REDIS_URL=redis://redis:6379
REDIS_COLLABORATION_URL=redis://redis:6379

FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data

OIDC_DISPLAY_NAME=Outline Login
OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=change_me_oidc_client_secret
OIDC_AUTH_URI=https://auth.docs.example.com/auth
OIDC_TOKEN_URI=http://dex:5556/token
OIDC_USERINFO_URI=http://dex:5556/userinfo
OIDC_SCOPES=openid profile email
OIDC_USERNAME_CLAIM=preferred_username

FORCE_HTTPS=true
ENABLE_UPDATES=false
